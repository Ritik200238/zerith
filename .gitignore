.vercel

# burner / hot-wallet files — never commit. Wildcards catch any future
# sibling files (.burner-funder.json, .beefy-burner.json, etc.) so a
# careless `git add .` from a fresh clone cannot leak a privkey.
.burner-*.json
.beefy-*.json
.burner-wallet.json
.multibid-burners.json
