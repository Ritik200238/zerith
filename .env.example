PRIVATE_KEY=0x_your_private_key_here
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Frontend embedded burner ("Try Instantly") ───────────────────────
# Set these in cipherdex/frontend/.env.local locally, and in Vercel's
# Project Environment Variables for prod. NEVER commit real values.
#
# BURNER_FUNDER_PRIVATE_KEY: privkey of a hot wallet on Sepolia that holds
# a small budget of testnet ETH used to seed each demo burner. Must NOT be
# the deployer key on a real network — keep this isolated to testnet.
BURNER_FUNDER_PRIVATE_KEY=0x_set_a_dedicated_sepolia_hot_wallet_key_here
# Optional: amount of Sepolia ETH each burner gets. Default 0.008 ETH.
BURNER_FUND_AMOUNT_ETH=0.008
# Optional: per-IP cooldown in milliseconds. Default 6 hours.
BURNER_RATE_LIMIT_WINDOW_MS=21600000
