# Frontend env. Copy to .env.local and fill the values. .env.local is gitignored.
#
# Required for the "Try Instantly" embedded-burner demo flow
# (POST /api/burner/create). Without these, the API responds 503 and the
# landing CTA shows a fallback message — MetaMask still works.
BURNER_FUNDER_PRIVATE_KEY=0x_set_a_dedicated_sepolia_hot_wallet_key_here

# Sepolia JSON-RPC. Defaults to publicnode if unset, but a private endpoint
# (Alchemy/Infura) is recommended in production for rate-limit resilience.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional knobs
# BURNER_FUND_AMOUNT_ETH=0.008
# BURNER_RATE_LIMIT_WINDOW_MS=21600000
